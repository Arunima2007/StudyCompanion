generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DifficultyLabel {
  AGAIN
  EASY
  MEDIUM
  HARD
}

model User {
  id                         String          @id @default(cuid())
  name                       String
  email                      String          @unique
  passwordHash               String?
  googleId                   String?         @unique
  createdAt                  DateTime        @default(now())
  updatedAt                  DateTime        @updatedAt
  lastLoginAt                DateTime?
  hasCompletedOnboardingTour Boolean         @default(false)
  currentStreak              Int             @default(0)
  maxStreak                  Int             @default(0)
  totalStudyDays             Int             @default(0)
  maxActiveDays              Int             @default(0)
  subjects                   Subject[]
  reviewAttempts             ReviewAttempt[]
  dailyActivities            DailyActivity[]
}

model Subject {
  id          String    @id @default(cuid())
  userId      String
  title       String
  description String?
  color       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapters    Chapter[]
}

model Chapter {
  id          String      @id @default(cuid())
  subjectId   String
  title       String
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  subject     Subject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  notes       Note[]
  flashCards  FlashCard[]
}

model Note {
  id        String   @id @default(cuid())
  chapterId String
  title     String
  content   String?
  fileUrl   String?
  createdAt DateTime @default(now())
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
}

model FlashCard {
  id                     String          @id @default(cuid())
  chapterId              String
  type                   String
  question               String
  referenceAnswer        String
  hint                   String?
  sourceSnippet          String?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  reviewCount            Int             @default(0)
  successfulRecallCount  Int             @default(0)
  averageScore           Float           @default(0)
  difficultyLabel        DifficultyLabel @default(MEDIUM)
  lastReviewedAt         DateTime?
  nextReviewAt           DateTime?
  chapter                Chapter         @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  reviewAttempts         ReviewAttempt[]
}

model ReviewAttempt {
  id              String          @id @default(cuid())
  flashCardId     String
  userId          String
  userAnswer      String
  aiFeedback      Json
  aiScore         Float
  difficultyLabel DifficultyLabel
  reviewedAt      DateTime        @default(now())
  nextReviewAt    DateTime?
  flashCard       FlashCard       @relation(fields: [flashCardId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyActivity {
  id            String   @id @default(cuid())
  userId        String
  date          DateTime
  cardsReviewed Int      @default(0)
  minutesStudied Int     @default(0)
  streakActive  Boolean  @default(false)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}
